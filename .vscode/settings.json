{
    "workbench.preferredLightColorTheme": "Light+",
    "chat.agent.enabled": false,
    "telemetry.telemetryLevel": "error",
    "workbench.editor.highlightModifiedTabs": true,
    "sftp.debug": true,
    "sftp.printDebugLog": true,
    "editor.cursorBlinking": "smooth",
    "window.titleBarStyle": "native",
    "window.dialogStyle": "custom",
    "window.menuStyle": "custom",
    "workbench.tree.enableStickyScroll": false,
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "markdown.updateLinksOnFileMove.enabled": "always",
    "terminal.integrated.stickyScroll.enabled": false,
    "workbench.preferredHighContrastColorTheme": "Light+",
    "workbench.startupEditor": "readme",
    "window.autoDetectColorScheme": true,
    "search.collapseResults": "alwaysCollapse",
    "search.defaultViewMode": "tree",
    "focus.opacity": "0.2",
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.tabs.defaultIcon": "terminal-bash",
    "terminal.integrated.suggest.enabled": true,
    "npm.enableRunFromFolder": true,
    "editor.suggest.preview": true,
    "emmet.useInlineCompletions": true,
    "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
    "workbench.editor.pinnedTabSizing": "shrink",
    "editor.stickyTabStops": true,
    "editor.tabCompletion": "on",
    "zenMode.showTabs": "single",
    "explorer.confirmUndo": "verbose",
    "explorer.confirmDragAndDrop": false,
    "security.promptForLocalFileProtocolHandling": false,
    "focus.highlightLines": 3,
    "focus.highlightRange": "none",
    "vim.startofline": false,
    "vim.useCtrlKeys": false,
    "workbench.tree.indent": 20,
    "explorer.confirmDelete": false,
    "editor.fontFamily": "'Ubuntu Mono'",
    "markdown.preview.fontFamily": "\"Noto Sans\", \"Fira Sans\", \"Noto Sans\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
    "editor.stickyScroll.enabled": false,
    "search.showLineNumbers": true,
    "editor.hover.above": false,
    "workbench.sash.hoverDelay": 0,
    "js/ts.hover.maximumLength": 20,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.view.alwaysShowHeaderActions": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "editor.mouseMiddleClickAction": "openLink",
    "editor.mouseWheelZoom": true,
    "accessibility.dimUnfocused.opacity": 0.4,
    "workbench.editor.alwaysShowEditorActions": true,
    "chat.sendElementsToChat.enabled": false,
    "files.simpleDialog.enable": true,
    "editor.showFoldingControls": "always",
    "editor.lineNumbers": "relative",
    "git.confirmSync": false,
    "workbench.colorCustomizations": {},
    "terminal.integrated.cursorStyle": "underline",
    "git.autofetch": true,
    "material-icon-theme.folders.color": "#77ccff",
    "workbench.experimental.share.enabled": true,
    "editor.minimap.showSlider": "always",
    "workbench.editor.closeEmptyGroups": false,
    "workbench.preferredDarkColorTheme": "Dark 2026",
    "accessibility.signals.clear": {
        "sound": "on"
    },
    "accessibility.signals.codeActionApplied": {
        "sound": "on"
    },
    "accessibility.signals.format": {
        "announcement": "always",
        "sound": "always"
    },
    "accessibility.signals.lineHasError": {
        "sound": "on"
    },
    "accessibility.signals.lineHasInlineSuggestion": {
        "sound": "on"
    },
    "accessibility.signals.progress": {
        "sound": "on"
    },
    "accessibility.signals.save": {
        "sound": "always"
    },
    "accessibility.signals.terminalCommandSucceeded": {
        "sound": "on"
    },
    "accessibility.signalOptions.volume": 30,
    "workbench.editor.tabSizingFixedMaxWidth": 250,
    "workbench.editor.enablePreview": false,
    "workbench.settings.applyToAllProfiles": [
        "simpleBrowser.focusLockIndicator.enabled"
    ],
    "markdown.occurrencesHighlight.enabled": true,
    "markdown.preview.doubleClickToSwitchToEditor": false,
    "markdown.preview.markEditorSelection": false,
    "editor.aiStats.enabled": true,
    "simpleBrowser.useIntegratedBrowser": true,
    "chat.disableAIFeatures": true,
    "terminal.integrated.initialHint": false,
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://schema.tauri.app": true
    },
    "workbench.browser.openLocalhostLinks": true,
    "editor.minimap.enabled": false,
    "workbench.iconTheme": "a-file-icon-vscode",
    "material-icon-theme.activeIconPack": "none",
    "material-icon-theme.saturation": 0.7
}